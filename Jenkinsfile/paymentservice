pipeline {
    agent any

    tools {
        jdk 'jdk17'
        nodejs 'node20'
    }
    
    environment {
        SCANNER_HOME = tool 'sonar-scanner'
        DOCKER_NAME  = 'gsathya7/paymentservice'
        IMAGE_NAME   = 'paymentservice'
    }

    stages {

        stage("Clean Workspace") {
            steps {
                cleanWs()
            }
        }

        stage("Git Checkout") {
            steps {
                git branch: 'main', url: 'https://github.com/SathyaG7/Google-microservices-devsecops-project.git'
            }
        }

        stage("SonarQube Analysis") {
            steps {
                dir('src/paymentservice') {
                    withSonarQubeEnv('sonar-server') {
                        sh '''
                        $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectKey=paymentservice \
                        -Dsonar.projectName=paymentservice \
                        -Dsonar.sources=. \
                        -Dsonar.language=js
                        '''
                    }
                }
            }
        }

        stage("Quality Gate") {
            steps {
                script {
                    timeout(time: 3, unit: 'MINUTES') {
                        waitForQualityGate abortPipeline: true, credentialsId: 'sonar-token'
                    }
                }
            }
        }

        stage("Install Dependencies") {
            steps {
                dir('src/paymentservice') {
                    sh 'npm install'
                }
            }
        }

        stage("OWASP Dependency Check") {
            steps {
                dir('src/paymentservice') {
                    catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {

                        dependencyCheck additionalArguments: '''
                            --scan ./ 
                            --disableYarnAudit 
                            --disableNodeAudit
                        ''',
                        odcInstallation: 'dp-check'

                        dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
                    }
                }
            }
            post {
                always {
                    archiveArtifacts 'src/paymentservice/dependency-check-report.xml'
                }
            }
        }

        stage("Trivy File Scan") {
            steps {
                dir('src/paymentservice') {
                    sh '''
                    trivy fs . \
                    --severity CRITICAL,HIGH \
                    --exit-code 1 \
                    --scanners vuln,misconfig,secret \
                    > trivy-fs-report.txt || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts 'src/paymentservice/trivy-fs-report.txt'
                }
            }
        }

        stage("Build Docker Image") {
            steps {
                dir('src/paymentservice') {
                    script {
                        env.IMAGE_TAG = "$DOCKER_NAME:${BUILD_NUMBER}"

                        sh "docker rmi -f $IMAGE_NAME ${IMAGE_TAG} || true"
                        sh "docker build -t $IMAGE_NAME ."
                        sh "docker tag $IMAGE_NAME ${IMAGE_TAG}"
                    }
                }
            }
        }

        stage("Push Docker Image") {
            steps {
                dir('src/paymentservice') {
                    withCredentials([string(credentialsId: 'docker-cred', variable: 'dockerpwd')]) {
                        sh '''
                        docker login -u gsathya7 -p ${dockerpwd}
                        docker push ${IMAGE_TAG}
                        docker tag ${IMAGE_NAME} ${DOCKER_NAME}:latest
                        docker push ${DOCKER_NAME}:latest
                        '''
                    }
                }
            }
        }

        stage("Trivy Image Scan") {
            steps {
                dir('src/paymentservice') {
                    sh '''
                    trivy image -f json -o trivy-image-payment.json ${IMAGE_TAG}
                    trivy image -f table -o trivy-image-payment.txt ${IMAGE_TAG}
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts 'src/paymentservice/trivy-image-payment.*'
                }
            }
        }

    }
}
