pipeline {
    agent any

    tools {
        jdk 'jdk17'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
        DOCKER_NAME  = 'gsathya7/recommendationservice'
        IMAGE_NAME   = 'recommendationservice'
    }

    stages {

        stage("Clean Workspace") {
            steps {
                cleanWs()
            }
        }

        stage("Git Checkout") {
            steps {
                git branch: 'main', url: 'https://github.com/SathyaG7/Google-microservices-devsecops-project.git'
            }
        }

        stage("Bandit Security Scan") {
            steps {
                dir('src/recommendationservice') {
                    sh '''
                    bandit -r . -f json -o bandit-report.json || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'src/recommendationservice/bandit-report.json', allowEmptyArchive: true
                }
            }
        }

        stage("SonarQube Analysis") {
            steps {
                dir('src/recommendationservice') {
                    withSonarQubeEnv('sonar-server') {
                        sh '''
                        $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectKey=recommendationservice \
                        -Dsonar.projectName=recommendationservice \
                        -Dsonar.sources=. \
                        -Dsonar.language=py
                        '''
                    }
                }
            }
        }

        stage("Quality Gate") {
            steps {
                script {
                    timeout(time: 3, unit: 'MINUTES') {
                        waitForQualityGate abortPipeline: true, credentialsId: 'sonar-token'
                    }
                }
            }
        }

        stage("Install Dependencies") {
            steps {
                dir('src/recommendationservice') {
                    sh '''
                    pip3 install -r requirements.txt || true
                    '''
                }
            }
        }

        stage("Safety Dependency Scan") {
            steps {
                dir('src/recommendationservice') {
                    sh '''
                    safety check --full-report --output json > safety-report.json || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'src/recommendationservice/safety-report.json', allowEmptyArchive: true
                }
            }
        }

        stage("Trivy File Scan") {
            steps {
                dir('src/recommendationservice') {
                    sh '''
                    trivy fs . --severity CRITICAL,HIGH --scanners vuln,misconfig,secret > trivy-fs-report.txt || true
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'src/recommendationservice/trivy-fs-report.txt', allowEmptyArchive: true
                }
            }
        }

        stage("Build Docker Image") {
            steps {
                dir('src/recommendationservice') {
                    script {
                        env.IMAGE_TAG = "$DOCKER_NAME:${BUILD_NUMBER}"

                        sh "docker build -t $IMAGE_NAME ."
                        sh "docker tag $IMAGE_NAME ${IMAGE_TAG}"
                    }
                }
            }
        }

        stage("Push Docker Image") {
            steps {
                dir('src/recommendationservice') {
                    withCredentials([string(credentialsId: 'docker-cred', variable: 'dockerpwd')]) {
                        sh '''
                        docker login -u gsathya7 -p ${dockerpwd}
                        docker push ${IMAGE_TAG}
                        docker tag ${IMAGE_NAME} ${DOCKER_NAME}:latest
                        docker push ${DOCKER_NAME}:latest
                        '''
                    }
                }
            }
        }

        stage("Trivy Image Scan") {
            steps {
                dir('src/recommendationservice') {
                    sh '''
                    trivy image -f json -o trivy-image-recommendation.json ${IMAGE_TAG}
                    trivy image -f table -o trivy-image-recommendation.txt ${IMAGE_TAG}
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'src/recommendationservice/trivy-image-recommendation.*', allowEmptyArchive: true
                }
            }
        }

    }
}
